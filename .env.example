# Copy this file to ".env" and fill in your values. ".env" is gitignored.

# Remote diagnostics — OPTIONAL. Gates the settings dashboard's diagnostics endpoints so
# the always-on server can be troubleshot over the LAN without shell access to the box:
#   GET  /api/status/logs?tail=200&level=warn   -> recent [refresh]/[collector]/[api/*] lines
#                                                  (secret-scrubbed; see lib/logbuffer.mjs)
#   POST /api/status/refresh                     -> force a baked-data refresh now
#   POST /api/status/collect                     -> force one price-collector pass now
# UNSET = these three endpoints are DISABLED (return 503). GET /api/status stays open either way.
# Set a long random secret (e.g. `openssl rand -hex 32`) and pass it as
#   Authorization: Bearer <token>   (or ?token=<token>). Server-side only, never echoed back.
# DIAG_TOKEN=

# SWU (swu-db) and Disney Lorcana (Lorcast, api.lorcast.com) need NO key — keyless,
# proxied through this dev server for CORS. Lorcast also carries daily USD prices.

# Riftbound (Scrydex) — OPTIONAL. Adds live market pricing + a price-trend graph.
# Riftbound covers all sets keyless without it (baked data + Riftscribe; eBay for AUD prices).
SCRYDEX_API_KEY=your_scrydex_api_key
SCRYDEX_TEAM_ID=your_scrydex_team_id

# Pokemon (pokemontcg.io) — OPTIONAL. Lookups work without it (lower rate limit).
# Add a free key from https://dev.pokemontcg.io/dashboard to get 20,000 req/day.
POKEMONTCG_API_KEY=your_pokemontcg_api_key

# LEGO builder — primary lookup. Free, self-service key from your Rebrickable
# account settings (https://rebrickable.com/api/). Set/minifig/parts data.
REBRICKABLE_API_KEY=your_rebrickable_api_key

# LEGO builder — enrichment (RRP/retail price, age range, dimensions). Free key
# requested at https://brickset.com/tools/webservices/requestkey
BRICKSET_API_KEY=your_brickset_api_key

# LEGO builder — secondary-market pricing (new vs used). BrickLink OAuth1: create
# a "consumer" at https://www.bricklink.com/v2/api/register_consumer.page and
# register this server's outbound IP. All four values required for pricing.
BRICKLINK_CONSUMER_KEY=your_bricklink_consumer_key
BRICKLINK_CONSUMER_SECRET=your_bricklink_consumer_secret
BRICKLINK_TOKEN=your_bricklink_token
BRICKLINK_TOKEN_SECRET=your_bricklink_token_secret

# eBay — live AUD pricing + comps via the eBay Browse API (powers the Funko builder
# AND Riftbound AUD price comps), and Funko item-
# specifics via the Taxonomy API. Free dev keys (App ID + Cert ID) from
# https://developer.ebay.com/. EBAY_MARKETPLACE selects the site (EBAY_AU = AU).
#
# IMPORTANT: use your *PRODUCTION* keyset, NOT sandbox. The proxy calls the live
# eBay API (api.ebay.com), so sandbox keys (the Cert ID / App ID contain "SBX-")
# fail the OAuth step with invalid_client. Production keys contain "PRD-".
# EBAY_APP_ID = "App ID (Client ID)";  EBAY_CERT_ID = "Cert ID (Client Secret)".
# Paste with no surrounding quotes or trailing spaces.
# Quick self-test (replace the two values):
#   curl -s -H "Authorization: Basic $(printf '%s:%s' "$EBAY_APP_ID" "$EBAY_CERT_ID" | base64 -w0)" \
#     -d 'grant_type=client_credentials&scope=https://api.ebay.com/oauth/api_scope' \
#     https://api.ebay.com/identity/v1/oauth2/token
# A JSON access_token = good; {"error":"invalid_client"} = wrong/sandbox keys.
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_MARKETPLACE=EBAY_AU
# eBay USER-token refresh token (shared): the bulk tool's future Sell-Inventory push AND the
# store repricer (lib/ebay-oauth.mjs) both use ONE eBay user token on this keyset. Two ways to
# get it: (a) run the repricer's one-time browser consent (needs EBAY_RUNAME below) — it stores
# the token encrypted in data/ebay-oauth.json, OR (b) paste a refresh token here. Server-side
# only, never in the browser or a committed file. Requires a production keyset APPROVED for the
# sell.inventory scope (a separate eBay review). The CSV export path
# (bulk-listing-builder.html → /api/bulk/export/csv) needs no user token at all.
#EBAY_REFRESH_TOKEN=

# ---- Store repricer + Telegram (NEW) --------------------------------------
# Telegram alerts + one-tap Approve/Skip for the store repricer (lib/repricer.mjs).
# Phase 1 needs ONLY these two. Unset = repricer routes still load but stay quiet
# (no poller, /test-alert returns a helpful 503).
#
# 1) Create a bot: message @BotFather on Telegram -> /newbot -> copy the token
#    (looks like  123456789:AAExampleToken...). Paste it here (no quotes).
# 2) Add the bot to your team channel/group. For a CHANNEL it must be an ADMIN.
# 3) Find the chat id: run the dev server, then  GET /api/repricer/chatid
#    (the bot records any chat it's added to). Channel/supergroup ids look like -100...
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
#
# eBay USER token (Phase 2+: read OWN listings via GetMyeBaySelling + raise prices via
# ReviseInventoryStatus). NOT needed for Phase 1. EBAY_RUNAME = the RuName from your Production
# keyset's "User Tokens" page (a plain localhost URL is REJECTED by eBay — use the RuName). Set it,
# then open /api/repricer/oauth and consent once as the seller; the resulting refresh token is the
# SAME shared token as EBAY_REFRESH_TOKEN above (mints the sell.inventory scope both tools need).
EBAY_RUNAME=

# Pre-grading tool (card-grader.html) — AI vision condition pass. OPTIONAL: centering
# measurement + valuation work fully KEYLESS; an API key only adds the corners/edges/surface
# scoring. Set EITHER an Anthropic OR an OpenAI key (or both). GRADER_PROVIDER picks which:
#   auto (default) = use Anthropic if its key is set, else OpenAI.
#   anthropic | openai = force one provider.
# GRADER_MODEL optionally overrides the model (defaults: claude-opus-4-8 / gpt-4o).
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GRADER_PROVIDER=auto
# GRADER_MODEL=claude-opus-4-8

# PriceCharting (Pokemon graded/raw/pop prices in the extras panel) — fully OPTIONAL.
# Works KEYLESS by default: it scrapes the public card + population pages server-side
# (no free API exists). Nothing to set for the default behaviour.
#   PRICECHARTING_ENABLED=false  -> turn the feature off entirely.
#   PRICECHARTING_TOKEN=...      -> if you later buy a Retailer subscription, set the API
#                                   token here and the proxy uses the official API instead
#                                   of scraping (same output). 40-char token from the
#                                   PriceCharting subscriptions "API/Download" button.
# PRICECHARTING_ENABLED=true
# PRICECHARTING_TOKEN=your_pricecharting_api_token

# UPCItemDB (SEALED-inventory barcode -> product) — fully OPTIONAL, KEYLESS by default.
# PriceCharting's public search CANNOT resolve a UPC (only its paid API can), so the sealed scanner
# resolves a barcode to a product name + image via UPCItemDB's free "trial" endpoint (no key; ~100
# lookups/day, 6/min per IP), then finds the live PriceCharting price by NAME. This is what makes most
# sealed barcode scans work; without it a scan can only hit the local cache + manual entry.
#   UPCITEMDB_ENABLED=false  -> turn the barcode->name bridge off.
#   UPCITEMDB_KEY=...        -> a paid UPCItemDB user_key raises the rate limit (uses /prod/v1).
# UPCITEMDB_ENABLED=true
# UPCITEMDB_KEY=your_upcitemdb_user_key

# Sealed inventory NIGHTLY value refresh (lib/sealed.mjs). Re-values held sealed stock automatically:
# eBay AU delivered comps (your market, AUD) PRIMARY, PriceCharting (USD) fallback; every valuation is
# recorded with its source in the sealed_valuations history. On by default (needs eBay keys above for
# the eBay path; without them it uses PriceCharting only).
#   SEALED_VALUE_REFRESH_ENABLED=false  -> turn the nightly auto-refresh off (manual button still works).
#   SEALED_VALUE_REFRESH_HOURS=24       -> interval in hours (default 24 = nightly).
# SEALED_VALUE_REFRESH_ENABLED=true
# SEALED_VALUE_REFRESH_HOURS=24

# Graded-card inventory (inventory.html) — cert-number auto-fill. OPTIONAL.
# The inventory "Add card" form always works by MANUAL entry. Cert lookup is multi-company
# (data/grading-companies.json): PSA is the only grader with a public cert API, so a PSA token
# enables real auto-fill (paste a cert -> fills card + grade). BGS/CGC/SGC/TAG/ARK/PCG have no
# public API — those just deep-link to the company's official verify page + you fill fields in.
# Unset -> PSA lookup reports "unavailable"; everything else still works (Golden Rule 7).
# Request a token from PSA's developer portal (https://www.psacard.com/publicapi).
# PSA_API_TOKEN=your_psa_public_api_token
#
# The PSA API is quota-capped (as low as 1 call/day on the public tier), so cert lookup FALLS
# BACK to reading the public cert page (the same URL the "Verify" link opens) — no quota, works
# with or without a token. It uses the system `curl` (built into Windows 10+/macOS/Linux) since
# node's fetch is Cloudflare-blocked. Set PSA_CERT_SCRAPE=false to disable and use the API only.
# PSA_CERT_SCRAPE=true

# Shipping label printer (shipping-label.html -> AUSPRINT PRO / Rongta thermal printer,
# raw TCP 9100) — OPTIONAL. Unset = the Shipping Label Maker stays download-only (the
# Print button is disabled, Download still works). The browser rasterises each label and
# POSTs it to /api/print, which streams TSPL straight to the printer. Confirmed: AUSPRINT
# PRO speaks TSPL and renders BITMAP with 0=black (the code handles the inversion).
#
# Find the printer's IP in your router's DHCP client list — it's the device that answers
# on port 9100 ONLY (no web page). Give it a DHCP reservation so the IP never moves.
LABEL_PRINTER_IP=192.168.4.220
# LABEL_PRINTER_PORT=9100         # raw / JetDirect port (default 9100)
# LABEL_PRINTER_LANG=tspl         # tspl (AUSPRINT PRO — confirmed) | zpl (other Rongta firmware)
# LABEL_PRINTER_DPI=300           # AUSPRINT PRO = 300; base AUSPRINT = 203. Must match the unit.
# LABEL_PRINTER_PAGE_W_MM=100     # FALLBACK label size only — the app prints at whichever size is
# LABEL_PRINTER_PAGE_H_MM=50      #   selected in the tool (50×30 / 100×50); these apply if omitted.
# LABEL_PRINTER_GAP_MM=3          # die-cut gap between labels
# LABEL_PRINTER_OFFX_MM=0         # seeds the in-app "Print nudge X" — shifts the PRINTED label
# LABEL_PRINTER_OFFY_MM=0         #   left/right & up/down to match your printer (negative = left/up).
#                                 # The AUSPRINT historically needs about -4 on the X; re-measure on the 100mm portrait web.
# LABEL_PRINTER_DENSITY=10        # 0–15 darkness. Start 10 (proven solid black). Too high bleeds 1D bars and
#                                 #   merges the datamatrix on Australia Post 100×150; sweep 6/8/10/12 on real stock.
# LABEL_PRINTER_SPEED=2           # print speed in/s. 2 matches the AUSPRINT vendor app; slower = crisper barcodes.
#                                 # TSPL only (ZPL emits no SPEED). The in-app Darkness/Speed steppers override these
#                                 #   per print (clamped, falling back to these values).
# LABEL_PRINTER_INVERT=false      # set true ONLY if labels come out as a photo-negative
