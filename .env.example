# Copy this file to ".env" and fill in your values. ".env" is gitignored.

# Riftbound (Scrydex) — required for the Riftbound builder.
SCRYDEX_API_KEY=your_scrydex_api_key
SCRYDEX_TEAM_ID=your_scrydex_team_id

# Pokemon (pokemontcg.io) — OPTIONAL. Lookups work without it (lower rate limit).
# Add a free key from https://dev.pokemontcg.io/dashboard to get 20,000 req/day.
POKEMONTCG_API_KEY=your_pokemontcg_api_key
