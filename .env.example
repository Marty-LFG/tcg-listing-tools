# Copy this file to ".env" and fill in your values. ".env" is gitignored.

# Riftbound (Scrydex) — OPTIONAL. Adds live market pricing + a price-trend graph.
# Riftbound covers all sets keyless without it (baked data + Riftscribe; eBay for AUD prices).
SCRYDEX_API_KEY=your_scrydex_api_key
SCRYDEX_TEAM_ID=your_scrydex_team_id

# Pokemon (pokemontcg.io) — OPTIONAL. Lookups work without it (lower rate limit).
# Add a free key from https://dev.pokemontcg.io/dashboard to get 20,000 req/day.
POKEMONTCG_API_KEY=your_pokemontcg_api_key

# LEGO builder — primary lookup. Free, self-service key from your Rebrickable
# account settings (https://rebrickable.com/api/). Set/minifig/parts data.
REBRICKABLE_API_KEY=your_rebrickable_api_key

# LEGO builder — enrichment (RRP/retail price, age range, dimensions). Free key
# requested at https://brickset.com/tools/webservices/requestkey
BRICKSET_API_KEY=your_brickset_api_key

# LEGO builder — secondary-market pricing (new vs used). BrickLink OAuth1: create
# a "consumer" at https://www.bricklink.com/v2/api/register_consumer.page and
# register this server's outbound IP. All four values required for pricing.
BRICKLINK_CONSUMER_KEY=your_bricklink_consumer_key
BRICKLINK_CONSUMER_SECRET=your_bricklink_consumer_secret
BRICKLINK_TOKEN=your_bricklink_token
BRICKLINK_TOKEN_SECRET=your_bricklink_token_secret

# eBay — live AUD pricing + comps via the eBay Browse API (powers the Funko builder
# AND Riftbound AUD price comps), and Funko item-
# specifics via the Taxonomy API. Free dev keys (App ID + Cert ID) from
# https://developer.ebay.com/. EBAY_MARKETPLACE selects the site (EBAY_AU = AU).
#
# IMPORTANT: use your *PRODUCTION* keyset, NOT sandbox. The proxy calls the live
# eBay API (api.ebay.com), so sandbox keys (the Cert ID / App ID contain "SBX-")
# fail the OAuth step with invalid_client. Production keys contain "PRD-".
# EBAY_APP_ID = "App ID (Client ID)";  EBAY_CERT_ID = "Cert ID (Client Secret)".
# Paste with no surrounding quotes or trailing spaces.
# Quick self-test (replace the two values):
#   curl -s -H "Authorization: Basic $(printf '%s:%s' "$EBAY_APP_ID" "$EBAY_CERT_ID" | base64 -w0)" \
#     -d 'grant_type=client_credentials&scope=https://api.ebay.com/oauth/api_scope' \
#     https://api.ebay.com/identity/v1/oauth2/token
# A JSON access_token = good; {"error":"invalid_client"} = wrong/sandbox keys.
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_MARKETPLACE=EBAY_AU

# Pre-grading tool (card-grader.html) — AI vision condition pass. OPTIONAL: centering
# measurement + valuation work fully KEYLESS; an API key only adds the corners/edges/surface
# scoring. Set EITHER an Anthropic OR an OpenAI key (or both). GRADER_PROVIDER picks which:
#   auto (default) = use Anthropic if its key is set, else OpenAI.
#   anthropic | openai = force one provider.
# GRADER_MODEL optionally overrides the model (defaults: claude-opus-4-8 / gpt-4o).
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GRADER_PROVIDER=auto
# GRADER_MODEL=claude-opus-4-8

# PriceCharting (Pokemon graded/raw/pop prices in the extras panel) — fully OPTIONAL.
# Works KEYLESS by default: it scrapes the public card + population pages server-side
# (no free API exists). Nothing to set for the default behaviour.
#   PRICECHARTING_ENABLED=false  -> turn the feature off entirely.
#   PRICECHARTING_TOKEN=...      -> if you later buy a Retailer subscription, set the API
#                                   token here and the proxy uses the official API instead
#                                   of scraping (same output). 40-char token from the
#                                   PriceCharting subscriptions "API/Download" button.
# PRICECHARTING_ENABLED=true
# PRICECHARTING_TOKEN=your_pricecharting_api_token
