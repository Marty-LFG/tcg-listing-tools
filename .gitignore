# eBay channel secrets + artifacts (bulk listing tool) — NEVER commit.
# data/ebay-oauth.json holds the Sell-API refresh token (a long-lived credential);
# data/ebay-categories.json is a pinned live-Taxonomy cache; data/exports/ holds
# generated listing CSVs. data/samples/ (test fixtures) stays tracked.
data/ebay-oauth.json
data/ebay-*.json
!data/ebay-listing.config.example.json
data/exports/

# Generated on-disk caches (not source): PriceCharting scrape results + proxied card images.
data/pc-cache/
data/img-cache/

# Rotated SQLite snapshots written by lib/backup.mjs (VACUUM INTO tracker.db/repricer.db + a
# config bundle). Local disaster-recovery copies, not source — and they may contain data/.env if
# include_secrets is enabled, so they must NEVER be committed.
data/backups/

# Baked data catalogs (build artifacts, NOT source): regenerated in place on a timer by
# lib/refresh.mjs from the tracked seeds + live upstreams (TCGdex / Riot). Tracking them made
# every deploy collide with the server's own rebuild. Seeds stay tracked as the source of truth
# (data/pokemon-intl-seed.json); regenerate the bakes with
#   node scripts/build-pokemon-intl-sets.mjs   &&   node scripts/build-riftbound-data.mjs
# (or just let the 60s boot refresh repopulate them). funko_pop.json / pokemon-dex-en.json stay
# tracked — their upstreams are frozen / built by hand, so they don't churn.
data/pokemon-intl-sets.json
data/riftbound.json
# EN early/pre-release set bake (regenerated by the pokemon-en-early bake from the tracked seed
# data/pokemon-en-early-seed.json + PriceCharting). Same rationale — a tracked bake collides with the
# server's own rebuild. Re-seeded from the seed on boot (lib/refresh.mjs ensureEnEarlySeeded).
data/pokemon-en-early.json

# Mega Evolution Promo roster (regenerated by the pokemon-mep bake from TCGplayer's search API +
# the Scrydex image CDN). Same rationale — a tracked bake collides with the server's own rebuild.
# Re-seeded from data/pokemon-mep-seed.json on boot (lib/refresh.mjs ensureMepSeeded).
data/pokemon-mep.json

# Runtime-editable config the settings dashboard writes at runtime — SERVER-OWNED so its live edits
# never collide with git pulls (tracking it did: it had to be skip-worktree'd on the server, which
# then blocked every pull). data/refresh.config.example.json is the tracked template; a missing file
# falls back to DEFAULT_CONFIG and is re-seeded from the example on boot (lib/refresh.mjs).
data/refresh.config.json
# Post-sale automation runtime config — SERVER-OWNED (settings dashboard writes it). Re-seeded from
# the tracked data/postsale.config.example.json on boot (lib/postsale.mjs ensureConfigSeeded).
data/postsale.config.json
# eBay listing config — SERVER-OWNED. Holds the account's stable business-policy IDs + merchant
# location (filled by POST /api/listings/account/bootstrap) + listing defaults; re-seeded from the
# tracked data/ebay-listing.config.example.json on boot (lib/listings.mjs ensureConfigSeeded).
data/ebay-listing.config.json
